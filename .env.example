# ── Supabase ──────────────────────────────────────────────────
# Encontre em: app.supabase.com → projeto → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Só para serverless functions (nunca expor no frontend)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ── Câmbio ────────────────────────────────────────────────────
# Cadastro gratuito em: exchangerate-api.com
EXCHANGE_RATE_API_KEY=sua_api_key_aqui

# ── Email (Resend) ────────────────────────────────────────────
# Cadastro em: resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Cron ──────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
CRON_SECRET=seu_secret_aleatorio_aqui

# ── Links de Afiliado ─────────────────────────────────────────
# Preencher após aprovação em cada programa
AFFILIATE_WISE_LINK=https://wise.prf.hn/click/camref:SEU_CAMREF
AFFILIATE_REMITLY_LINK=https://www.remitly.com/us/en/brazil?irclickid=SEU_TAG
AFFILIATE_WU_LINK=https://wu.prf.hn/click/camref:SEU_CAMREF

# ── Voos (Travelpayouts) ──────────────────────────────────────
# Cadastro em: travelpayouts.com
TRAVELPAYOUTS_TOKEN=seu_token_aqui
TRAVELPAYOUTS_MARKER=seu_marker_aqui
AFFILIATE_KAYAK_LINK=https://www.kayak.com/in?a=SEU_ID&url=
