# ── Supabase ──────────────────────────────────────────────────
# Encontre em: app.supabase.com → projeto → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Só para serverless functions (nunca expor no frontend)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ── Câmbio ────────────────────────────────────────────────────
# Cadastro gratuito em: exchangerate-api.com
EXCHANGE_RATE_API_KEY=sua_api_key_aqui

# ── Email (Resend) ────────────────────────────────────────────
# Cadastro em: resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Cron ──────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
CRON_SECRET=seu_secret_aleatorio_aqui

# ── Links de Afiliado — Remessas ──────────────────────────────
AFFILIATE_WISE_LINK=https://wise.prf.hn/click/camref:SEU_CAMREF
AFFILIATE_REMITLY_LINK=https://www.remitly.com/us/en/brazil?irclickid=SEU_TAG
AFFILIATE_WU_LINK=https://wu.prf.hn/click/camref:SEU_CAMREF

# ── Voos (Travelpayouts) ──────────────────────────────────────
TRAVELPAYOUTS_TOKEN=seu_token_aqui
TRAVELPAYOUTS_MARKER=seu_marker_aqui
AFFILIATE_KAYAK_LINK=https://www.kayak.com/in?a=SEU_ID&url=

# ── Afiliados Tier 0 — Quick Wins (Fase 3 Módulo 03) ──────────
# Cadastrar em cada programa, copiar o link e colar aqui
AFFILIATE_LEMONADE_LINK=https://www.lemonade.com/?ref=SEU_REF
AFFILIATE_MINT_LINK=https://www.mintmobile.com/?ref=SEU_REF
AFFILIATE_MERCURY_LINK=https://mercury.com/r/SEU_REF
AFFILIATE_MYUS_LINK=https://www.myus.com/?id=SEU_ID
AFFILIATE_ZENBUSINESS_LINK=https://www.zenbusiness.com/?affiliate=SEU_ID
AFFILIATE_CAPITALONE_LINK=https://www.capitalone.com/?af=SEU_ID

# ── Afiliados Viagem (Fase 2 Módulo 11) ───────────────────────
AFFILIATE_BOOKING_LINK=https://www.booking.com/index.html?aid=SEU_AID
AFFILIATE_EXPEDIA_LINK=https://www.expedia.com/?siteid=SEU_ID
AFFILIATE_UNDERCOVER_LINK=https://www.undercovertourist.com/?aid=SEU_AID
AFFILIATE_KLOOK_LINK=https://www.klook.com/?aid=SEU_AID
AFFILIATE_VIATOR_LINK=https://www.viator.com/?pid=SEU_PID
AFFILIATE_GETYOURGUIDE_LINK=https://www.getyourguide.com/?partner_id=SEU_ID

# ── SEO / Analytics (Fase 3 Módulo 06) ────────────────────────
# Substituir placeholders no index.html depois de criar contas
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX   # https://analytics.google.com
# META_PIXEL_ID=XXXXXXXXXXXXXXX     # https://business.facebook.com

# ── Admin (Lista de Espera) ───────────────────────────────────
# Gerar com: openssl rand -hex 32
# Usado pelo /api/admin/waitlist e pelo painel /admin/waitlist
ADMIN_SECRET=seu_segredo_admin_aqui

# ── Email de origem (Resend / waitlist) ───────────────────────
# Precisa estar com domínio verificado no Resend
# Default: BrasilConnect USA <oi@brasilconnectusa.com>
WAITLIST_FROM_EMAIL=BrasilConnect USA <oi@brasilconnectusa.com>

# ── Stripe (AgendaPro — Fase 2 módulo 01) ─────────────────────
# stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# stripe.com → Products → criar 3 planos:
# Starter $19/mês | Pro $39/mês | Salão $79/mês
STRIPE_PRICE_STARTER=price_xxxx
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_SALON=price_xxxx

# ── Z-API (WhatsApp) ──────────────────────────────────────────
# z-api.io → Instâncias
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── App URL (usado por links de email, Stripe success_url, etc) ──
APP_URL=https://brasilconnectusa.com
